# ============================================
# CONVENEHUB Frontend Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values.

# Backend API base URL (production).
# Leave empty for local Vite proxy usage.
# Example: https://your-backend-service.up.railway.app
VITE_API_BASE_URL=

# Local proxy target (used in development with Vite proxy)
# Example: http://127.0.0.1:8080
VITE_API_PROXY_TARGET=

# ============================================
# QR CODE SECURITY (Required for Bookings)
# ============================================
# Secret key for signing QR codes (minimum 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
QR_HMAC_SECRET="convenehub-secret-key-2025-change-this-in-production-min-32-characters"

# ============================================
# RAZORPAY CONFIGURATION (Required for Payments)
# ============================================
# Get these from: https://dashboard.razorpay.com -> Settings -> API Keys

# Razorpay Key ID (Test/Live mode)
# This is safe to expose to the client
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx

# Razorpay Key Secret
# Never expose this to the client - only use in API routes
RAZORPAY_KEY_SECRET=your-razorpay-secret-key-here

# Razorpay Webhook Secret (for webhook signature verification)
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret-here

# ============================================
# EMAIL CONFIGURATION (Required for Bookings)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=technical@convenehub.in
SMTP_PASSWORD=your-app-password-here
SMTP_FROM_EMAIL="ConveneHub Events" <technical@convenehub.in>
SMTP_REPLY_TO=technical@convenehub.in

# Site URL for email links
NEXT_PUBLIC_SITE_URL=https://convenehub.vercel.app
