{
  "root": true,
  "env": {
    "browser": true,
    "es2022": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "plugins": ["react-hooks"],
  "extends": [
    "eslint:recommended",
    "plugin:react-hooks/recommended"
  ],
  "rules": {
    "react-hooks/exhaustive-deps": "off",
    "no-empty": "off",
    "no-useless-escape": "off",
    "prefer-const": "off",
    "no-control-regex": "off",
    "no-useless-catch": "off"
  },
  "ignorePatterns": ["dist", "node_modules"]
}
